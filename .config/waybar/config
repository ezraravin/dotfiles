{
    "layer": "top",
    "position": "top",
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window",
        "sway/workspaces",
        "sway/window",
    ],
    "modules-right": [
        "bluetooth",
        "network",
        "pulseaudio",
        "battery",
        "clock",
        "custom/brightness",
        "power-profiles-daemon",
        "custom/power"
    ],
    "hyprland/window": {
        "max-length": 50
    },
    "hyprland/workspaces": {
        "format": "{name}"    
    },
    "bluetooth": {
        "format": "ΎΛΦ",
        "format-disabled": "≤░Γ▓",  // Bluetooth icon with a slash
        "on-click": "blueman-manager"
    },
    "network": {
        "tooltip": true,
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nBandwidth: <b>ΎΑβ  {bandwidthDownBytes} ΎΓΥ  {bandwidthUpBytes}</b>",
        "format-wifi": "ΎΘτ   {essid} ({signalStrength}%)",
        "format-disconnected": "≤░Ψς Disconnected",
        "format-ethernet": "≤░ΙΑ {ipaddr}/{cidr}",
        "format-linked": "{ifname} (No IP) ΎηΨ",
        "interval": 2,
        "on-click": "nmtui"
    },
    "custom/brightness": {
        "format": "ΎΗΖ  {}%",
        "interval": 1,
        "exec": "brightnessctl -m | awk -F, '{print substr($4, 0, length($4)-1)}'",
        "exec-if": "command -v brightnessctl",  // Only run if brightnessctl exists
        "on-click-up": "brightnessctl set +5%",
        "on-click-down": "brightnessctl set 5%-",
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-",
        "tooltip": false,
        "signal": 8  // Force refresh on signal (optional)
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-alt": "{format_source}",
        "format-bluetooth": "{icon} ΎΛΦ {volume}%",
        "format-bluetooth-muted": "≤░Γ▓",
        "format-muted": "≤░ζθ Muted",
        "format-source": "ΎΕ░ {volume}%",
        "format-source-muted": "ΎΕ▒ Muted",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΑξ",
            "default": ["ΎΑο", "ΎΑπ ", "ΎΑρ  "]
        },
        "on-click-right": "pavucontrol",
        "scroll-step": 5,
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "format-icons": {
            "performance": "ΎΔπ",
            "balanced": "≤░╛Ζ",
            "power-saver": "ΎΒυ"
        }
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "≤░ΓΕ {capacity}%",
        "format-plugged": "≤░γξ {capacity}%",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "interval": 5
    },
    "clock": {
        "format": "{:%H:%M %p}",
        "format-alt": "{:%a, %d %b %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#ff6699'><b>{}</b></span>",
                "days": "<span color='#cdd6f4'><b>{}</b></span>",
                "weekdays": "<span color='#7CD37C'><b>{}</b></span>",
                "today": "<span color='#ffcc66'><b>{}</b></span>"
            }
        }
    },
    "custom/power": {
        "format": "έΠ╗",
        "on-click": "wlogout"
    }
}

