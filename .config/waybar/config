{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // "height": 0, // Waybar height (to be removed for auto height)
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "cpu",
        "temperature",
        "memory",
        "pulseaudio",
        "network",
        "battery",
        "power-profiles-daemon",
    ],
    // Modules configuration
    "hyprland/workspaces": {
         "format": "{name}",
         "format-icons": {
            "1": "",
            "2": "",
            "3": "",
            "10": "",
            "5": "",
            "urgent": "",
            "active": "",
            "default": ""
         }
     },
     "tray": 
     {
        "spacing": 8,
        "icon-size": 16
     },
    "tray": {
        "icon-size": 16,
        "spacing": 8
    },
    "clock": {
        "format": "{:%H:%M %p}",
        "format-alt": "{:%a, %d %b %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": 
        {
            "mode": "month",
            "format": 
            {
                "months": "<span color='#ff6699'><b>{}</b></span>",
                "days": "<span color='#cdd6f4'><b>{}</b></span>",
                "weekdays": "<span color='#7CD37C'><b>{}</b></span>",
                "today": "<span color='#ffcc66'><b>{}</b></span>"
            }
        }
    },
    "cpu": 
    {
        "format": "{icon0} {icon1} {icon2} {icon3}",
     	"format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"],    
        "interval": 2
    },
    "memory": {
        "format": "{percentage}% ",
        "format-alt": "{used:0.1f}GB/{total:0.1f}GB",
        "unit": "GB"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}°C {icon}",
        "format-icons": [ "" ]
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}   {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "",
        "performance": "",
        "balanced": "󰾅",
        "power-saver": ""
      }
    },
    "network": {
        "tooltip": true,
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>",
        "format-wifi": "   {essid} ({signalStrength}%)",
        "format-disconnected": "󰖪   Disconnected",
        "format-ethernet": "󰈀   {ipaddr}/{cidr}",
        "format-linked": "{ifname} (No IP) ",
        "format-disconnected": "Disconnected ⚠",

        "format-alt": "<span foreground='#f9e2af'>  {bandwidthDownBytes}</span>  <span foreground='#f9e2af'>  {bandwidthUpBytes}</span>",
        "interval": 2,
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-alt": "{format_source}",
        "format-bluetooth": "{icon} {volume}%",
        "format-bluetooth-muted": "󰂲",
        "format-muted": "󰝟 Muted",
        "format-source": " {volume}%",
        "format-source-muted": "",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },
}
