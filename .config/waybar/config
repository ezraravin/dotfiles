{
    "layer": "top",
    "position": "top",
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window",
        "sway/workspaces",
        "sway/window"
    ],
    "modules-right": [
        "bluetooth",
        "network",
        "pulseaudio",
        "battery",
        "clock",
        "power-profiles-daemon",
        "custom/power"
    ],
    "hyprland/window": {
        "max-length": 50
    },
    "hyprland/workspaces": {
        "format": "{name}"    
    },
    "bluetooth": {
        "format": "",
        "format-disabled": "󰂲",  // Bluetooth icon with a slash
        "on-click": "blueman-manager"
    },
    "network": {
        "tooltip": true,
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>\nBandwidth: <b>  {bandwidthDownBytes}   {bandwidthUpBytes}</b>",
        "format-wifi": "  {essid} ({signalStrength}%)",
        "format-disconnected": "󰖪 Disconnected",
        "format-ethernet": "󰈀 {ipaddr}/{cidr}",
        "format-linked": "{ifname} (No IP) ",
        "interval": 2,
        "on-click": "nmtui"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-alt": "{format_source}",
        "format-bluetooth": "{icon}  {volume}%",
        "format-bluetooth-muted": "󰂲",
        "format-muted": "󰝟 Muted",
        "format-source": " {volume}%",
        "format-source-muted": " Muted",
        "format-icons": {
            "headphone": "",
            "hands-free": "",
            "headset": "",
            "default": ["", " ", "  "]
        },
        "on-click-right": "pavucontrol",
        "scroll-step": 5,
    },
    "power-profiles-daemon": {
        "format": "{icon}",
        "format-icons": {
            "performance": "",
            "balanced": "󰾅",
            "power-saver": ""
        }
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "interval": 5
    },
    "clock": {
        "format": "{:%H:%M %p}",
        "format-alt": "{:%a, %d %b %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "format": {
                "months": "<span color='#ff6699'><b>{}</b></span>",
                "days": "<span color='#cdd6f4'><b>{}</b></span>",
                "weekdays": "<span color='#7CD37C'><b>{}</b></span>",
                "today": "<span color='#ffcc66'><b>{}</b></span>"
            }
        }
    },
    "custom/power": {
        "format": "⏻",
        "on-click": "wlogout"
    }
}

