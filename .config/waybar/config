{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    // "height": 0, // Waybar height (to be removed for auto height)
    "spacing": 4, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "cpu",
        "temperature",
        "memory",
        "pulseaudio",
        "network",
        "battery",
        "power-profiles-daemon",
        "custom/power",
    ],
    // Modules configuration
    "hyprland/workspaces": {
         "format": "{name}",
         "format-icons": {
            "1": "яДа",
            "2": "яЙи",
            "3": "яДб",
            "10": "яЖ╝",
            "5": "яБ╡",
            "urgent": "яБк",
            "active": "яЖТ",
            "default": "яДС"
         }
     },
     "tray": 
     {
        "spacing": 8,
        "icon-size": 16
     },
    "tray": {
        "icon-size": 16,
        "spacing": 8
    },
    "clock": {
        "format": "{:%H:%M %p}",
        "format-alt": "{:%a, %d %b %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": 
        {
            "mode": "month",
            "format": 
            {
                "months": "<span color='#ff6699'><b>{}</b></span>",
                "days": "<span color='#cdd6f4'><b>{}</b></span>",
                "weekdays": "<span color='#7CD37C'><b>{}</b></span>",
                "today": "<span color='#ffcc66'><b>{}</b></span>"
            }
        }
    },
    "cpu": 
    {
        "format": "{icon0} {icon1} {icon2} {icon3}",
     	"format-icons": ["тЦБ", "тЦВ", "тЦГ", "тЦД", "тЦЕ", "тЦЖ", "тЦЗ", "тЦИ"],    
        "interval": 2
    },
    "memory": {
        "format": "{percentage}% яГЙ",
        "format-alt": "{used:0.1f}GB/{total:0.1f}GB",
        "unit": "GB"
    },
    "temperature": {
        "critical-threshold": 80,
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": [ "яЛЙ" ]
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format-full": "{capacity}% {icon}",
        "format": "{icon} {capacity}%",
        "format-charging": "ґ░ВД {capacity}%",
        "format-plugged": "ґ░Ъе {capacity}%",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "power-profiles-daemon": {
      "format": "{icon}",
      "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
      "tooltip": true,
      "format-icons": {
        "default": "яГз",
        "performance": "яГз",
        "balanced": "ґ░╛Е",
        "power-saver": "яБм"
      }
    },
    "network": {
        "tooltip": true,
        "tooltip-format": "Network: <big><b>{essid}</b></big>\nSignal strength: <b>{signaldBm}dBm ({signalStrength}%)</b>\nFrequency: <b>{frequency}MHz</b>\nInterface: <b>{ifname}</b>",
        "format-wifi": "яЗл   {essid} ({signalStrength}%)",
        "format-disconnected": "ґ░Цк   Disconnected",
        "format-ethernet": "ґ░ИА   {ipaddr}/{cidr}",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "Disconnected тЪа",

        "format-alt": "<span foreground='#f9e2af'>яАЩ  {bandwidthDownBytes}</span>  <span foreground='#f9e2af'>яВУ  {bandwidthUpBytes}</span>",
        "interval": 2,
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-alt": "{format_source}",
        "format-bluetooth": "{icon} яКФ {volume}%",
        "format-bluetooth-muted": "ґ░В▓",
        "format-muted": "ґ░ЭЯ Muted",
        "format-source": "яД░ {volume}%",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яАе",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
    },
}
