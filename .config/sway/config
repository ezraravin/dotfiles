########################
### WINDOW RULES ###
########################
assign [class="kitty"] → workspace 1
assign [class="Brave-browser"] → workspace 2
assign [class="obs"] → workspace 3
assign [class="kdenlive"] → workspace 4
assign [class="whatsapp-linux-app"] → workspace 10

####################
### NVIDIA CONFIG ##
####################
set $env:LIBVA_DRIVER_NAME nvidia
set $env:__GLX_VENDOR_LIBRARY_NAME nvidia
set $env:NVD_BACKEND direct

# Enable mouse window dragging
bindsym $mod+button1 move window
bindsym $mod+button3 resize window

# Scratchpad implementation
bindsym $mod+Shift+m move scratchpad
bindsym $mod+m scratchpad show