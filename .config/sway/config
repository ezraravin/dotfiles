
################
### VARIABLES ##
################
set $mod Mod4
set $terminal kitty
set $fileManager nautilus
set $menu wofi --show drun
set $refreshWallpaper ~/.config/sway/scripts/random-wallpapers.sh

###############
### AUTOSTART #
###############
exec nm-applet
exec $terminal
exec waybar
exec swaybg -m fill -i ~/Pictures/wallpaper.png
exec spotify
exec brave
exec spotify-adblock

# Wallpaper refresh (using systemd timer instead of while loop)
exec_always ~/.config/sway/scripts/wallpaper-timer.sh

########################
### ENVIRONMENT VARS ##
########################
set $env:XCURSOR_SIZE 24

###################
### LOOK & FEEL ##
###################
# Gaps (requires sway-git)
gaps inner 4
gaps outer 8
smart_gaps on

# Borders
default_border pixel 1
default_floating_border pixel 1
hide_edge_borders smart

################
### INPUT ###
################
input "type:keyboard" {
    repeat_rate 60
    repeat_delay 200
    xkb_layout us
}

input "type:touchpad" {
    natural_scroll enabled
    tap enabled
}

#################
### KEYBINDS ###
#################
# Basic
bindsym $mod+Return exec $terminal
bindsym $mod+q kill
bindsym $mod+e exec $fileManager
bindsym $mod+f fullscreen
bindsym $mod+d exec $menu
bindsym $mod+r exec $refreshWallpaper

# Window management
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+0 workspace number 10

bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+0 move container to workspace number 10

# Multimedia keys
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86MonBrightnessUp exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

# Player controls
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioPrev exec playerctl previous

