################
### MONITORS ###
################

output HDMI-A-1 {
    resolution 2560x1080@75Hz
    position auto
    scale 1.0
}

output DP-1 {
    resolution 1920x1080@60Hz
    position auto
    scale 1.0
    transform 270 # Rotate 90° counter-clockwise (equivalent to Hyprland's `transform,3`)
}

###################
### MY PROGRAMS ###
###################

set $terminal kitty
set $fileManager nautilus
set $menu wofi --show drun
set $refreshWallpaper ~/.config/sway/scripts/random-wallpapers.sh

#################
### AUTOSTART ###
#################

exec nm-applet --indicator
exec $terminal
exec waybar
exec swaybg -i ~/Pictures/Wallpapers/default.jpg -m fill
exec spotify
exec brave
exec spotify-adblock

# Change wallpaper every 60 minutes
exec bash -c "while true; do sleep 3600; $refreshWallpaper; done"

#############################
### ENVIRONMENT VARIABLES ###
#############################

env = XCURSOR_SIZE,24

#####################
### LOOK AND FEEL ###
#####################

# Gaps (similar to Hyprland)
gaps inner 4
gaps outer 8

# Borders
default_border pixel 1
default_floating_border pixel 1
hide_edge_borders smart

# Colors (Sway doesn't support RGBA, so simplified)
client.focused          #33ccff #33ccff #ffffff #33ccff
client.unfocused        #595959 #595959 #888888 #595959

# No blur in Sway (use a solid background)
# No animations in Sway (static tiling)

#############
### INPUT ###
#############

input * {
    repeat_rate 60
    repeat_delay 200
    xkb_layout us
}

# Touchpad (if applicable)
input type:touchpad {
    natural_scroll enabled
}

# No gestures in Sway (use `libinput-gestures` separately if needed)

###################
### KEYBINDINGS ###
###################

set $mainMod Mod4 # Super (Windows) key

# Basic apps
bindsym $mainMod+Return exec $terminal
bindsym $mainMod+q kill
bindsym $mainMod+e exec $fileManager
bindsym $mainMod+space exec $menu
bindsym $mainMod+f fullscreen

# Floating/tiling
bindsym $mainMod+y floating toggle
bindsym $mainMod+d layout toggle split

# Move focus
bindsym $mainMod+h focus left
bindsym $mainMod+j focus down
bindsym $mainMod+k focus up
bindsym $mainMod+l focus right

# Move windows
bindsym $mainMod+Shift+h move left
bindsym $mainMod+Shift+j move down
bindsym $mainMod+Shift+k move up
bindsym $mainMod+Shift+l move right

# Resize windows
bindsym $mainMod+Left resize shrink width 60px
bindsym $mainMod+Down resize grow height 60px
bindsym $mainMod+Up resize shrink height 60px
bindsym $mainMod+Right resize grow width 60px

# Workspaces
bindsym $mainMod+1 workspace 1
bindsym $mainMod+2 workspace 2
bindsym $mainMod+3 workspace 3
bindsym $mainMod+4 workspace 4
bindsym $mainMod+5 workspace 5
bindsym $mainMod+6 workspace 6
bindsym $mainMod+7 workspace 7
bindsym $mainMod+8 workspace 8
bindsym $mainMod+9 workspace 9
bindsym $mainMod+0 workspace 10

# Move windows to workspaces
bindsym $mainMod+Shift+1 move container to workspace 1
bindsym $mainMod+Shift+2 move container to workspace 2
bindsym $mainMod+Shift+3 move container to workspace 3
bindsym $mainMod+Shift+4 move container to workspace 4
bindsym $mainMod+Shift+5 move container to workspace 5
bindsym $mainMod+Shift+6 move container to workspace 6
bindsym $mainMod+Shift+7 move container to workspace 7
bindsym $mainMod+Shift+8 move container to workspace 8
bindsym $mainMod+Shift+9 move container to workspace 9
bindsym $mainMod+Shift+0 move container to workspace 10

# Scratchpad (similar to Hyprland's "special workspace")
bindsym $mainMod+m move scratchpad
bindsym $mainMod+Shift+m move container to scratchpad

# Multimedia keys
bindsym XF86AudioRaiseVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym XF86AudioLowerVolume exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym XF86AudioMute exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym XF86AudioMicMute exec wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle
bindsym XF86MonBrightnessUp exec brightnessctl set +10%
bindsym XF86MonBrightnessDown exec brightnessctl set 10%-

# Player controls
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioPrev exec playerctl previous

##############################
### WINDOWS AND WORKSPACES ###
##############################

# Assign apps to workspaces
assign [class="kitty"] 1
assign [class="Brave-browser"] 2
assign [class="obs"] 3
assign [class="kdenlive"] 4
assign [class="whatsapp-linux-app"] 10
assign [class="Spotify"] scratchpad

# Floating windows (optional)
for_window [class="Spotify"] floating enable